{% extends 'base.html.twig' %}

{% block title %}Profile{% endblock %}

{% block body %}
    <h1>Liste de ses articles</h1>
    <div class="row">
        {% for article in articles %}
        <div class="col-lg-4 col-12">
            <div class="card my-3">
                <div class="card-body">
                    <h5 class="card-title">{{ article.title }}</h5>
                    <p class="card-text">{{ article.description }}</p>
                    
                    {% if article.author %}
                    <p class="card-text">Auteur : {{ article.author.firstname }} {{ article.author.lastname }}</p>
                    {% endif %}

                    <a href="{{ path('app_article_show', {'id' : article.id } ) }}" class="card-link">Afficher</a>
                    <a href="{{ path('app_article_edit', {'id' : article.id } ) }}" class="card-link">Éditer</a>

                    {% if is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('app_article_delete', {'id' : article.id } ) }}" class="card-link">Supprimer</a>
                    {% endif %}
                </div>
            </div>
        </div>
        {% endfor %}
    </div>

    <h2>Liste des favoris</h2>
    <div class="row">
        {% for favori in favoris %}
        <div class="col-lg-4 col-12">
            <div class="card my-3">
                <div class="card-body">
                    <h5 class="card-title">{{ favori.produit.title }}</h5>                    
                    <a href="{{ path('app_produit_show', {'id' : favori.produit.id } ) }}" class="card-link">Afficher</a>
                    <a href="{{ path('app_favoris_delete', {'id' : favori.id } ) }}" class="card-link">Supprimer</a>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>


{% endblock %}
