{% extends 'base.html.twig' %}

{% block title %}Search{% endblock %}

{% block body %}
    <h1 class="text-center my-3">Recherche des articles</h1>
    <div class="row">
        {% for article in articles %}
        <div class="col-lg-4 col-12">
            <div class="card my-3">
                <div class="card-body">
                    <h5 class="card-title">{{ article.title }}</h5>
                    <p class="card-text">{{ article.description }}</p>
                    <a href="{{ path('app_article_show', {'id' : article.id } ) }}" class="card-link">Afficher</a>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
{% endblock %}
