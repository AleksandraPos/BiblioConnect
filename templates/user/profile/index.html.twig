{% extends 'base.html.twig' %}

{% block title %}Mon Profil - BiblioConnect{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="row">
        <div class="col-md-4">
            <div class="card shadow-sm mb-4">
                <div class="card-body text-center">
                    <i class="fas fa-user-circle fa-5x text-secondary mb-3"></i>
                    <h3>{{ app.user.firstName|default('Utilisateur') }} {{ app.user.lastName|default('') }}</h3>
                    <p class="text-muted">{{ app.user.email }}</p>
                    <span class="badge bg-primary">Membre BiblioConnect</span>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <h2 class="mb-4"><i class="fas fa-book-reader me-2"></i>Mes Réservations</h2>
            
            {% if app.user.reservations is empty %}
                <div class="alert alert-info">
                    Vous n'avez pas encore de réservations. <a href="{{ path('app_home') }}">Parcourir le catalogue</a>.
                </div>
            {% else %}
                <div class="table-responsive mb-5">
                    <table class="table table-hover shadow-sm border">
                        <thead class="table-light">
                            <tr>
                                <th>Livre</th>
                                <th>Date de début</th>
                                <th>Date de fin</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for reservation in app.user.reservations %}
                                <tr>
                                    <td><strong>{{ reservation.book.title }}</strong></td>
                                    <td>{{ reservation.startDate|date('d/m/Y') }}</td>
                                    <td>{{ reservation.endDate|date('d/m/Y') }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}

            <h2 class="mb-4 mt-5"><i class="fas fa-heart text-danger me-2"></i>Mes Coups de Cœur</h2>
            <div class="row">
                {% for fav in app.user.favorites %}
                    <div class="col-md-6 mb-3">
                        <div class="card h-100 border-light shadow-sm">
                            <div class="card-body d-flex align-items-center">
                                {% if fav.book.image %}
                                    <img src="{{ fav.book.image }}" alt="{{ fav.book.title }}" style="width: 50px; height: 70px; object-fit: cover;" class="me-3 rounded">
                                {% endif %}
                                <div>
                                    <h6 class="mb-1">{{ fav.book.title }}</h6>
                                    <p class="small text-muted mb-2">{{ fav.book.author }}</p>
                                    <div class="d-flex gap-2">
                                        <a href="{{ path('app_book_show', {'id': fav.book.id}) }}" class="btn btn-sm btn-outline-primary">Voir</a>
                                        <a href="{{ path('app_book_favorite', {'id': fav.book.id}) }}" class="btn btn-sm btn-outline-danger">
                                            <i class="fas fa-trash-alt"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                {% else %}
                    <div class="col-12">
                        <p class="text-muted italic">Vous n'avez pas еще de coups de cœur.</p>
                    </div>
                {% endfor %}
            </div>    
        </div>
    </div>
</div>
{% endblock %}