{% extends 'base.html.twig' %}

{% block title %}{{ book.title }}{% endblock %}

{% block body %}
<div class="container mt-5 mb-5">

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label == 'danger' ? 'danger' : (label == 'success' ? 'success' : 'info') }} alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}
    {% endfor %}
    
    <a href="{{ path('app_home') }}" class="btn btn-light mb-4 shadow-sm">← Retour au catalogue</a>

    <div class="row">
        <div class="col-md-4">
            {% if book.image %}
                <img src="{{ book.image }}" class="img-fluid rounded shadow" alt="{{ book.title }}">
            {% else %}
                <div class="bg-secondary text-white d-flex align-items-center justify-content-center rounded shadow" style="height: 400px;">
                    <i class="fas fa-book fa-4x"></i>
                </div>
            {% endif %}
        </div>
        <div class="col-md-8">
            <h1 class="display-4">{{ book.title }}</h1>
            <p class="lead text-muted">Par <strong>{{ book.author }}</strong></p>
            <hr>
            <div class="d-flex gap-3 mb-3">
                <p><strong>Catégorie :</strong> <span class="badge bg-primary">{{ book.category }}</span></p>
                <p><strong>Langue :</strong> <span class="badge bg-secondary">{{ book.language }}</span></p>
            </div>
            <p><strong>Stock disponible :</strong> 
                <span class="badge {{ book.stock > 0 ? 'bg-success' : 'bg-danger' }}">
                    {{ book.stock }} exemplaires
                </span>
            </p>
            
            <h3 class="mt-4">Résumé</h3>
            <p class="text-justify">{{ book.description }}</p>

            <div class="mt-5 d-flex align-items-center">
                {% if book.stock > 0 %}
                    <form action="{{ path('app_book_reserve', {'id': book.id}) }}" method="post" style="display:inline;">
                        <button type="submit" class="btn btn-success btn-lg px-4 shadow-sm">
                            <i class="fas fa-bookmark me-2"></i>Réserver ce livre
                        </button>
                    </form>
                {% else %}
                    <button class="btn btn-secondary btn-lg" disabled>Rupture de stock</button>
                {% endif %}

                <a href="{{ path('app_book_favorite', {'id': book.id}) }}" class="btn btn-outline-danger btn-lg ms-3 shadow-sm">
                    <i class="fas fa-heart"></i> Favoris
                </a>
            </div>
        </div>
    </div>

    <hr class="my-5">
    
    <div class="row mt-5">
        <div class="col-md-8">
            <h3><i class="fas fa-comments me-2"></i>Avis des lecteurs</h3>
            
            <div class="mt-4">
                {% for comment in book.comments %}
                    <div class="card mb-3 border-0 shadow-sm bg-light">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <strong><i class="fas fa-user-circle me-1"></i> {{ comment.author.email }}</strong>
                                <span class="badge bg-warning text-dark">
                                    {{ comment.rating }} / 5 <i class="fas fa-star text-white"></i>
                                </span>
                            </div>
                            <p class="mb-1">{{ comment.content }}</p>
                            <small class="text-muted">{{ comment.createdAt|date('d/m/Y H:i') }}</small>
                        </div>
                    </div>
                {% else %}
                    <div class="alert alert-light border">
                        Soyez le premier à donner votre avis sur ce livre !
                    </div>
                {% endfor %}
            </div>
        </div>

        <div class="col-md-4">
            {% if app.user %}
                <div class="card border-0 shadow-sm bg-white p-3">
                    <h4 class="mb-3">Laisser un avis</h4>
                    {{ form_start(commentForm) }}
                        <div class="mb-3">
                            {{ form_label(commentForm.rating, "Note sur 5") }}
                            {{ form_widget(commentForm.rating) }}
                        </div>
                        <div class="mb-3">
                            {{ form_label(commentForm.content, "Votre commentaire") }}
                            {{ form_widget(commentForm.content) }}
                        </div>
                        <button type="submit" class="btn btn-primary w-100">Publier l'avis</button>
                    {{ form_end(commentForm) }}
                </div>
            {% else %}
                <div class="card bg-light border-0 p-4 text-center">
                    <p class="mb-2">Vous voulez donner votre avis ?</p>
                    <a href="{{ path('app_login') }}" class="btn btn-outline-primary btn-sm">Connectez-vous</a>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}