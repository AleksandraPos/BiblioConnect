{% extends 'base.html.twig' %}

{% block title %}{{ book.title }}{% endblock %}

{% block body %}
<div class="container mt-5">

{% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}
    {% endfor %}
    
    <a href="{{ path('app_home') }}" class="btn btn-light mb-4">← Retour au catalogue</a>

    <div class="row">
        <div class="col-md-4">
            {% if book.image %}
                <img src="{{ book.image }}" class="img-fluid rounded shadow" alt="{{ book.title }}">
            {% else %}
                <div class="bg-secondary text-white d-flex align-items-center justify-content-center rounded" style="height: 400px;">
                    Pas d'image
                </div>
            {% endif %}
        </div>
        <div class="col-md-8">
            <h1 class="display-4">{{ book.title }}</h1>
            <p class="lead text-muted">Par <strong>{{ book.author }}</strong></p>
            <hr>
            <p><strong>Catégorie :</strong> <span class="badge bg-primary">{{ book.category }}</span></p>
            <p><strong>Langue :</strong> {{ book.language }}</p>
            <p><strong>Stock disponible :</strong> {{ book.stock }} exemplaires</p>
            
            <h3 class="mt-4">Résumé</h3>
            <p>{{ book.description }}</p>

            
<div class="mt-5">

    {% if book.stock > 0 %}
        <form action="{{ path('app_book_reserve', {'id': book.id}) }}" method="post" style="display:inline;">
            <button type="submit" class="btn btn-success btn-lg">
                Réserver ce livre
            </button>
        </form>
    {% else %}
        <button class="btn btn-secondary btn-lg" disabled>
            Rupture de stock
        </button>
    {% endif %}

    <button class="btn btn-outline-danger btn-lg ms-2">❤ Favoris</button>
</div>
        </div>
    </div>
</div>
{% endblock %}