{% extends 'base.html.twig' %}

{% block title %}Hello HomeController!{% endblock %}

{% block body %}
<div class="container mt-5">
    <h1>Bienvenue sur BiblioConnect</h1>

    <form action="{{ path('app_home') }}" method="get" class="mb-4 d-flex">
        <input type="text" name="q" value="{{ searchTerm }}" class="form-control me-2" placeholder="Rechercher par titre ou auteur...">
        <button type="submit" class="btn btn-primary">Rechercher</button>
    </form>

    <div class="row">
        {% for book in books %}
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm">
                    {% if book.image %}
                        <img src="{{ book.image }}" class="card-img-top" alt="{{ book.title }}" style="height: 250px; object-fit: cover;">
                    {% endif %}
                    <div class="card-body">
                        <h5 class="card-title">{{ book.title }}</h5>
                        <p class="card-text text-muted">Par {{ book.author }}</p>
                        <p class="card-text">{{ book.description|slice(0, 100) }}...</p>
                        <span class="badge bg-info">{{ book.category }}</span>
                    </div>
                    <div class="card-footer bg-transparent border-top-0">
                        <a href="{{ path('app_book_show', {'id': book.id}) }}" class="btn btn-outline-secondary w-100">Détails</a>
                    </div>
                </div>
            </div>
        {% else %}
            <p>Aucun livre trouvé.</p>
        {% endfor %}
    </div>
</div>
{% endblock %}
