{% extends 'base.html.twig' %}

{% block title %}BiblioConnect - Accueil{% endblock %}

{% block body %}
<div class="container mt-5">
    <h1>Bienvenue sur BiblioConnect</h1>

    <form action="{{ path('app_home') }}" method="get" class="mb-4 d-flex">
        <input type="text" name="q" value="{{ searchTerm }}" class="form-control me-2" placeholder="Rechercher par titre ou auteur...">
        <button type="submit" class="btn btn-primary">Rechercher</button>
    </form>

    <div class="row">
        {% for book in books %}
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm">
                    {% if book.image %}
                        <img src="{{ book.image }}" class="card-img-top" alt="{{ book.title }}" style="height: 250px; object-fit: cover;">
                    {% endif %}
                    
                    <div class="card-body">
                        <h5 class="card-title">{{ book.title }}</h5>
                        <p class="card-text text-muted">Par {{ book.author }}</p>
                        <p class="card-text">{{ book.description|slice(0, 100) }}...</p>
                        <span class="badge bg-info">{{ book.category }}</span>
                    </div>

                    <div class="card-footer bg-transparent border-top-0 d-flex gap-2">
                    
                        <a href="{{ path('app_book_show', {'id': book.id}) }}" class="btn btn-outline-secondary w-100">Détails</a>

                        {% if app.user %}
                            {% set isFavorite = false %}
                            {% for fav in app.user.favorites %}
                                {% if fav.id == book.id %}
                                    {% set isFavorite = true %}
                                {% endif %}
                            {% endfor %}

                            <a href="{{ path('app_book_favorite', {'id': book.id}) }}" 
                               class="btn {{ isFavorite ? 'btn-danger' : 'btn-outline-danger' }}">
                                <i class="{{ isFavorite ? 'fas' : 'far' }} fa-heart"></i>
                            </a>
                        {% else %}
    
                            <a href="{{ path('app_login') }}" class="btn btn-outline-danger">
                                <i class="far fa-heart"></i>
                            </a>
                        {% endif %}
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12">
                <p>Aucun livre trouvé.</p>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}