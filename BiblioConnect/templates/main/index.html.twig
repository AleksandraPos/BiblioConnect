{% extends 'base.html.twig' %}

{% block title %}Accueil - BiblioConnect{% endblock %}

{% block body %}
 <div class="container mt-5">
    <h1 class="text-center mb-5 text-primary">Bibliothèque Numérique</h1>

    <div class="row">
        {% for book in books %}
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm border-0">
                    <div class="bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                        <span class="text-muted small">Image non disponible</span>
                    </div>

                    <div class="card-body">
                        <h5 class="card-title fw-bold text-dark">{{ book.title }}</h5>
                        <p class="card-text mb-1"><strong>Auteur:</strong> {{ book.author }}</p>
                        <p class="card-text mb-2">
                            <span class="badge bg-info text-dark">{{ book.category.title|default('Général') }}</span>
                        </p>
                        <p class="card-text text-truncate" style="max-width: 100%;">{{ book.description|default('Aucune description disponible') }}</p>
                        </div>

                    <div class="card-footer bg-white border-0 pb-3">
                        <a href="{{ path('app_book_show', {'id': book.id}) }}" class="btn btn-outline-primary w-100">Voir les détails</a>
                </div>
            </div>
        {% else %}
            <div class="col-12 text-center">
                <div class="alert alert-warning">
                    Aucun livre n'est disponible pour le moment.
                </div>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}
