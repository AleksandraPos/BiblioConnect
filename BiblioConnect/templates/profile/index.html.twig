{% extends 'base.html.twig' %}

{% block title %}Mon Espace Personnel{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="row">
        <div class="col-md-4">
            <div class="card shadow-sm border-0 bg-light p-4 text-center">
                <div class="bi bi-person-circle text-primary mb-3" style="font-size: 4rem;"></div>
                <h4>{{ app.user.userIdentifier }}</h4>
                <p class="text-muted small">Email : {{ app.user.email }}</p>
                <div class="badge bg-primary">Rôle : {{ app.user.roles[0]|replace({'ROLE_': ''}) }}</div>
                <hr>
                <a href="{{ path('app_logout') }}" class="btn btn-outline-danger btn-sm">Se déconnecter</a>
            </div>
        </div>

        <div class="col-md-8">
            <h2 class="mb-4">Tableau de bord</h2>

            <div class="card shadow-sm mb-4 border-0">
                <div class="card-header bg-white fw-bold">Mes Emprunts en cours</div>
                <div class="card-body">
                    <ul class="list-group list-group-flush">
                        {% for reservation in app.user.reservations %}
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                <div>
                                    <span class="fw-bold text-dark">{{ reservation.book.title }}</span><br>
                                    <small class="text-muted">Emprunté le {{ reservation.createdAt|date('d/m/Y') }}</small>
                                </div>
                                <span class="badge bg-success rounded-pill">Actif</span>
                            </li>
                        {% else %}
                            <p class="text-muted small">Vous n'avez aucun livre emprunté pour le moment.</p>
                        {% endfor %}
                    </ul>
                </div>
            </div>

            <div class="card shadow-sm mb-4 border-0">
                <div class="card-header bg-white fw-bold text-danger">Mes Favoris</div>
                <div class="card-body">
                    <div class="row">
                        {% for fav in app.user.favorites %}
                            <div class="col-6 col-md-4 mb-3">
                                <div class="card h-100 border-0 shadow-sm">
                                    {% if fav.book.image %}
                                        <img src="{{ fav.book.image }}" class="card-img-top rounded" alt="{{ fav.book.title }}" style="height: 120px; object-fit: cover;">
                                    {% endif %}
                                    <div class="card-body p-2 text-center">
                                        <a href="{{ path('app_book_show', {id: fav.book.id}) }}" class="small text-decoration-none fw-bold text-truncate d-block">
                                            {{ fav.book.title }}
                                        </a>
                                    </div>
                                </div>
                            </div>
                        {% else %}
                            <p class="text-muted small">Votre liste de favoris est vide.</p>
                        {% endfor %}
                    </div>
                </div>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-header bg-white fw-bold">Mes Avis et Notes</div>
                <div class="card-body">
                    {% for review in app.user.reviews %}
                        <div class="border-bottom mb-3 pb-2">
                            <div class="text-warning mb-1">
                                {% for i in 1..5 %}
                                    <i class="bi bi-star{{ i <= review.rating ? '-fill' : '' }}"></i>
                                {% endfor %}
                            </div>
                            <p class="mb-1 small italic">"{{ review.comment }}"</p>
                            <small class="text-muted">Livre : <strong>{{ review.book.title }}</strong></small>
                        </div>
                    {% else %}
                        <p class="text-muted small">Vous n'avez pas encore rédigé d'avis.</p>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}