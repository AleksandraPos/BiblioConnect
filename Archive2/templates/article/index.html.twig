{% extends 'base.html.twig' %}

{% block title %}Hello ArticleController!{% endblock %}

{% block body %}
    <h1>Liste des articles</h1>

    <a href="{{ path('app_article_new') }}">Créer un article</a>
    <div class="row">
        {% for article in articles %}
        <div class="col-lg-4 col-12">
            <div class="card my-3">
                <div class="card-body">
                    <h5 class="card-title">{{ article.title }}</h5>
                    <p class="card-text">{{ article.description }}</p>
                    <a href="{{ path('app_article_show', {'id' : article.id } ) }}" class="card-link">Afficher</a>
                    <a href="{{ path('app_article_edit', {'id' : article.id } ) }}" class="card-link">Éditer</a>
                    <a href="{{ path('app_article_delete', {'id' : article.id } ) }}" class="card-link">Supprimer</a>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>

{% endblock %}
